+def gbrain_features_status(limit: int = 5) -> tuple[list[str], str, str | None]:
+    """Return compact GBrain feature health without leaking command output.
+
+    The brief is canonical Self-OS output, so GBrain is treated as an optional
+    local signal. Missing, unconfigured, timed out, or malformed GBrain state
+    must produce a clear note rather than fail brief generation.
+    """
+    if not GBRAIN_BIN.exists():
+        note = f"GBrain unavailable: `{GBRAIN_BIN}` not found."
+        return [note], "GBrain: unavailable; binary not found.", note
+
+    env = os.environ.copy()
+    env["HOME"] = GBRAIN_ENV_HOME
+    current_path = env.get("PATH", "")
+    env["PATH"] = f"{GBRAIN_ENV_PATH_PREFIX}:{current_path}" if current_path else GBRAIN_ENV_PATH_PREFIX
+
+    try:
+        proc = subprocess.run(
+            [str(GBRAIN_BIN), "features", "--json"],
+            cwd=str(REPO),
+            env=env,
+            text=True,
+            stdout=subprocess.PIPE,
+            stderr=subprocess.PIPE,
+            timeout=30,
+            check=False,
+        )
+    except subprocess.TimeoutExpired:
+        note = "GBrain unavailable: features scan timed out."
+        return [note], "GBrain: unavailable; features scan timed out.", note
+    except Exception as exc:  # pragma: no cover - defensive CLI output
+        note = f"GBrain unavailable: features scan could not start ({type(exc).__name__})."
+        return [note], "GBrain: unavailable; features scan could not start.", note
+
+    if proc.returncode != 0:
+        note = f"GBrain unavailable: features scan exited {proc.returncode}; check local GBrain config."
+        return [note], f"GBrain: unavailable; features scan exited {proc.returncode}.", note
+
+    try:
+        data = json.loads(proc.stdout)
+    except json.JSONDecodeError:
+        note = "GBrain unavailable: features scan returned unreadable JSON."
+        return [note], "GBrain: unavailable; unreadable features JSON.", note
+
+    if not isinstance(data, dict):
+        note = "GBrain unavailable: features scan returned unexpected JSON shape."
+        return [note], "GBrain: unavailable; unexpected features JSON.", note
+
+    score = data.get("brain_score")
+    score_text = str(score) if isinstance(score, (int, float, str)) and str(score).strip() else "unknown"
+    rows = [f"brain_score: `{one_line(score_text, 24)}/100`"]
+
+    recommendations = data.get("recommendations", [])
+    compact_recs: list[str] = []
+    if isinstance(recommendations, list):
+        parsed: list[tuple[str, str, int]] = []
+        for rec in recommendations:
+            if not isinstance(rec, dict):
+                continue
+            rec_id = one_line(rec.get("id", "unknown"), 48)
+            title = one_line(rec.get("title", "Untitled recommendation"), 80)
+            priority_raw = rec.get("priority", 99)
+            priority = priority_raw if isinstance(priority_raw, int) else 99
+            parsed.append((rec_id, title, priority))
+        for rec_id, title, _priority in sorted(parsed, key=lambda item: (item[2], item[0], item[1]))[:limit]:
+            compact_recs.append(f"`{rec_id}`: {title}")
+
+    if compact_recs:
+        rows.append("recommendations: " + "; ".join(compact_recs))
+        extra = len(recommendations) - len(compact_recs) if isinstance(recommendations, list) else 0
+        if extra > 0:
+            rows[-1] += f"; +{extra} more"
+    else:
+        rows.append("recommendations: none")
+
+    summary_recs = ", ".join(rec.replace("`", "") for rec in compact_recs[:3]) or "no recommendations"
+    return rows, f"GBrain: score {score_text}/100; {summary_recs}.", None
+
